# Скопируй в .env и заполни
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=avsoundmsk-ux
GITHUB_REPO=avsound
GITHUB_BRANCH=main
PORT=8080

# Seedance 2.0 — генерация видео через Volcengine / BytePlus Ark
ARK_API_KEY=
# Volcengine (Пекин):    https://ark.cn-beijing.volces.com/api/v3
# BytePlus (международ.): https://ark.ap-southeast.bytepluses.com/api/v3
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ID моделей/эндпоинтов из консоли Ark (seedance-2-0 / seedance-2-0-mini или ep-xxxxxxxx)
SEEDANCE_MODEL=seedance-2-0
SEEDANCE_MODEL_MINI=seedance-2-0-mini
